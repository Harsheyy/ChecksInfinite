# Supabase (DB mode — shows precomputed permutations from the database)
# Find these in: Supabase dashboard → Settings → API
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon_public_key>

# Alchemy (chain mode — live RPC calls, only needed without Supabase)
VITE_ALCHEMY_API_KEY=<your_alchemy_key>

# ChecksRecipeMinter contract (mainnet) — for the Mint Recipe flow in TreePanel
VITE_CHECKS_RECIPE_MINTER_ADDRESS=
